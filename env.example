# AUREUS Lottery - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# RÉSEAU - CHOISISSEZ UNE OPTION
# ============================================

# OPTION 1: BASE MAINNET (Production - Argent Réel)
# Utilisez cette configuration pour la production avec de l'argent réel
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASESCAN_TX_URL=https://basescan.org/tx/

# OPTION 2: BASE SEPOLIA (Testnet - Argent de Test)
# Utilisez cette configuration pour tester avec de l'argent de test
# NEXT_PUBLIC_CHAIN_ID=84532
# NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
# NEXT_PUBLIC_BASESCAN_TX_URL=https://sepolia.basescan.org/tx/

# ============================================
# ADRESSES DES SMART CONTRACTS
# ============================================

# Adresse du contrat de loterie (à remplacer par votre contrat déployé)
NEXT_PUBLIC_LOTTERY_ADDRESS=0xe94cFa075B46966e17Ad3Fc6d0676Eb9552ECEc6

# Adresse USDC
# Base Mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Adresse du propriétaire (pour les contrôles admin - peut déclencher les tirages)
NEXT_PUBLIC_OWNER_ADDRESS=

# Adresse Treasury (wallet Ledger pour recevoir les 10% - configurée par défaut)
NEXT_PUBLIC_TREASURY_ADDRESS=0xa166D2570d4bBfACcEBE7A78a426991b1Fa8f6eC

# ============================================
# MODE APPLICATION
# ============================================

# Mode par défaut: 'live' pour production, 'demo' pour tests
NEXT_PUBLIC_DEFAULT_MODE=live

# Mode forcé: 'live' pour verrouiller en mode opérationnel (recommandé pour production)
NEXT_PUBLIC_FORCE_MODE=live

# ============================================
# PAIEMENTS - CARTE BANCAIRE
# ============================================

# Ramp Network API Key (crypto on-ramp)
# Obtenir sur: https://ramp.network/
NEXT_PUBLIC_RAMP_API_KEY=

# Stripe API Keys (paiement fiat)
# Obtenir sur: https://stripe.com/
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ============================================
# SMART CONTRACT DÉPÔT
# ============================================

# Adresse du contrat AureusDeposit (après déploiement)
NEXT_PUBLIC_DEPOSIT_CONTRACT_ADDRESS=

# Adresse Uniswap Router (pour conversion multi-crypto)
# Base Mainnet: 0x2626664c2603336E57B271c5C0b26F421741e481 (Uniswap V3)
NEXT_PUBLIC_UNISWAP_ROUTER=

# ============================================
# SÉCURITÉ WALLET
# ============================================

# Seed pour génération déterministe des wallets (garder secret!)
WALLET_SEED=
